datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
  FARMER
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  phone                String?   @unique
  password             String
  role                 Role      @default(CUSTOMER)
  address              String?
  location             String?
  profileImage         String?
  nationalId           String?
  tinNumber            String?
  landMapFile          String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  
  // Farmer-specific fields
  farmName             String?
  farmSize             String?
  bio                  String?
  isVerified           Boolean   @default(false)
  certifications       String[]
  languages            String[]
  
  // Settings fields
  language             String    @default("English")
  timezone             String    @default("Africa/Addis_Ababa")
  
  // Payment settings
  bankName             String?
  accountNumber        String?
  paymentMethod        String?
  autoWithdrawal       Boolean   @default(false)
  withdrawalThreshold  Float?
  
  // Security settings
  twoFactor            Boolean   @default(false)
  loginAlerts          Boolean   @default(true)
  sessionTimeout       Int       @default(30)
  
  // Professional settings
  businessLicense      String?
  taxId                String?
  vatRegistered        Boolean   @default(false)
  vatNumber            String?
  insuranceProvider    String?
  insurancePolicy      String?
  insuranceExpiry      DateTime?
  farmRegistration     String?
  membershipAssociations String[]
  
  // Account status
  isActive             Boolean   @default(true)

  // Relations
  products             Product[]
  orders               Order[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  category    String?
  image       String?
  badges      String[]
  status      String   @default("pending")
  farmerId    Int
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                  Int         @id @default(autoincrement())
  orderCode           String
  customerId          Int?
  customer            User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items               Json        @default("[]")
  total               Float       @default(0)
  subtotal            Float       @default(0)
  deliveryFee         Float       @default(0)
  tax                 Float       @default(0)
  status              String      @default("processing")
  paymentMethod       String      @default("cash")
  paymentStatus       String      @default("unpaid")
  fullName            String?
  email               String?
  phone               String?
  city                String?
  address             String?
  additionalInfo      String?
  vendor              String?
  restaurant          String?
  estimatedDelivery   String?
  specialInstructions String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}
