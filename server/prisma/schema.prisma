datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
  FARMER
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  phone                String?   @unique
  password             String
  role                 Role      @default(CUSTOMER)
  address              String?
  location             String?
  profileImage         String?
  nationalId           String?
  tinNumber            String?
  landMapFile          String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())

  // Farmer-specific fields
  farmName       String?
  farmSize       String?
  bio            String?
  isVerified     Boolean  @default(false)
  certifications String[]
  languages      String[]

  // Settings fields
  language             String  @default("English")
  timezone             String  @default("Africa/Addis_Ababa")
  theme                String  @default("system")
  profileVisibility    String  @default("public")
  privateAccount       Boolean @default(false)
  showEmailOnProfile   Boolean @default(false)
  showPhoneOnProfile   Boolean @default(false)
  showAddressOnProfile Boolean @default(false)
  showOrderActivity    Boolean @default(true)
  emailNotifications   Boolean @default(true)
  pushNotifications    Boolean @default(true)
  smsNotifications     Boolean @default(false)

  // Payment settings
  bankName            String?
  accountNumber       String?
  paymentMethod       String?
  autoWithdrawal      Boolean @default(false)
  withdrawalThreshold Float?

  // Security settings
  twoFactor      Boolean @default(false)
  loginAlerts    Boolean @default(true)
  sessionTimeout Int     @default(30)

  // Professional settings
  businessLicense        String?
  taxId                  String?
  vatRegistered          Boolean   @default(false)
  vatNumber              String?
  insuranceProvider      String?
  insurancePolicy        String?
  insuranceExpiry        DateTime?
  farmRegistration       String?
  membershipAssociations String[]

  // Account status
  isActive Boolean @default(true)

  // Relations
  products           Product[]
  orders             Order[]
  orderItems         OrderItem[]
  notifications      Notification[]
  reviews            Review[]
  sentMessages       Message[]           @relation("SentMessages")
  receivedMessages   Message[]           @relation("ReceivedMessages")
  withdrawalRequests WithdrawalRequest[]

  @@index([role, isActive])
  @@index([role, isVerified])
  @@index([createdAt])
}

model Product {
  id               Int            @id @default(autoincrement())
  name             String
  description      String?
  price            Float
  stock            Int            @default(0)
  totalStock       Int?
  minOrderQuantity Int            @default(1)
  unit             String?
  category         String?
  brand            String?
  sku              String?
  discountPrice    Float?
  isOrganic        Boolean        @default(false)
  harvestDate      DateTime?
  expiryDate       DateTime?
  image            String?
  badges           String[]
  tags             String[]
  status           String         @default("pending")
  farmerId         Int
  farmer           User           @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  notifications    Notification[]
  reviews          Review[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Review {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId    Int?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  rating     Int
  comment    String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

model Order {
  id                  Int         @id @default(autoincrement())
  orderCode           String
  customerId          Int?
  customer            User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items               Json        @default("[]")
  total               Float       @default(0)
  subtotal            Float       @default(0)
  deliveryFee         Float       @default(0)
  tax                 Float       @default(0)
  status              String      @default("processing")
  paymentMethod       String      @default("cash")
  paymentStatus       String      @default("unpaid")
  fullName            String?
  email               String?
  phone               String?
  city                String?
  address             String?
  additionalInfo      String?
  vendor              String?
  restaurant          String?
  estimatedDelivery   String?
  specialInstructions String?
  orderItems          OrderItem[]
  reviews             Review[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([customerId, status])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float
  farmerId  Int
  farmer    User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([farmerId])
  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  tx_ref    String   @unique
  amount    Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   @default("SYSTEM")
  title     String
  message   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WithdrawalRequest {
  id          Int       @id @default(autoincrement())
  farmerId    Int
  amount      Float
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  farmer User @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}
