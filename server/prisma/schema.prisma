datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
  FARMER
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(CUSTOMER)
  phone                String?
  address              String?
  location             String?
  profileImage         String?
  nationalId           String?
  tinNumber            String?
  landMapFile          String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  
  // Farmer-specific fields
  farmName             String?
  farmSize             String?
  bio                  String?
  isVerified           Boolean   @default(false)
  certifications       String[]
  languages            String[]
  
  // Settings fields
  language             String    @default("English")
  timezone             String    @default("Africa/Addis_Ababa")
  
  // Payment settings
  bankName             String?
  accountNumber        String?
  paymentMethod        String?
  autoWithdrawal       Boolean   @default(false)
  withdrawalThreshold  Float?
  
  // Security settings
  twoFactor            Boolean   @default(false)
  loginAlerts          Boolean   @default(true)
  sessionTimeout       Int       @default(30)
  
  // Professional settings
  businessLicense      String?
  taxId                String?
  vatRegistered        Boolean   @default(false)
  vatNumber            String?
  insuranceProvider    String?
  insurancePolicy      String?
  insuranceExpiry      DateTime?
  farmRegistration     String?
  membershipAssociations String[]
  
  // Account status
  isActive             Boolean   @default(true)

  // Relations
  products             Product[]
  notifications        Notification[]
  orders               Order[]
  orderItems          OrderItem[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Float    @default(0)
  totalStock  Float    @default(0)
  minOrderQuantity Float @default(1)
  unit        String   @default("kg")
  category    String?
  brand       String?
  sku         String?
  discountPrice Float?
  isOrganic   Boolean  @default(false)
  harvestDate DateTime?
  expiryDate  DateTime?
  image       String?
  badges      String[]
  tags        String[]
  status      String   @default("pending")
  farmerId    Int
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  notifications Notification[]
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          Int      @id @default(autoincrement())
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Order {
  id          Int      @id @default(autoincrement())
  total       Float
  status      String   @default("pending")
  customerName String
  customerEmail String
  customerPhone String?
  customerAddress String?
  notes       String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int
  price       Float
  farmerId    Int
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}