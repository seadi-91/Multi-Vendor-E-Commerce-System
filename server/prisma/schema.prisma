datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
  FARMER
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  phone                String?   @unique
  password             String
  role                 Role      @default(CUSTOMER)
  address              String?
  location             String?
  profileImage         String?
  nationalId           String?
  tinNumber            String?
  landMapFile          String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  
  // Farmer-specific fields
  farmName             String?
  farmSize             String?
  bio                  String?
  isVerified           Boolean   @default(false)
  certifications       String[]
  languages            String[]
  
  // Settings fields
  language             String    @default("English")
  timezone             String    @default("Africa/Addis_Ababa")
  
  // Payment settings
  bankName             String?
  accountNumber        String?
  paymentMethod        String?
  autoWithdrawal       Boolean   @default(false)
  withdrawalThreshold  Float?
  
  // Security settings
  twoFactor            Boolean   @default(false)
  loginAlerts          Boolean   @default(true)
  sessionTimeout       Int       @default(30)
  
  // Professional settings
  businessLicense      String?
  taxId                String?
  vatRegistered        Boolean   @default(false)
  vatNumber            String?
  insuranceProvider    String?
  insurancePolicy      String?
  insuranceExpiry      DateTime?
  farmRegistration     String?
  membershipAssociations String[]
  
  // Account status
  isActive             Boolean   @default(true)

  // Relations
  products             Product[]
  orders               Order[]
  sentMessages         Message[] @relation("SentMessages")
  receivedMessages     Message[] @relation("ReceivedMessages")
  notifications        Notification[]
  withdrawalRequests   WithdrawalRequest[]
  orderItems           OrderItem[]

  @@index([role, isActive])
  @@index([role, isVerified])
  @@index([createdAt])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  category    String?
  image       String?
  badges      String[]
  status      String   @default("pending")
  farmerId    Int
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]

  @@index([farmerId, status])
  @@index([status])
  @@index([category])
}

model Order {
  id                  Int         @id @default(autoincrement())
  orderCode           String
  customerId          Int?
  customer            User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items               Json        @default("[]")
  total               Float       @default(0)
  subtotal            Float       @default(0)
  deliveryFee         Float       @default(0)
  tax                 Float       @default(0)
  status              String      @default("processing")
  paymentMethod       String      @default("cash")
  paymentStatus       String      @default("unpaid")
  fullName            String?
  email               String?
  phone               String?
  city                String?
  address             String?
  additionalInfo      String?
  vendor              String?
  restaurant          String?
  estimatedDelivery   String?
  specialInstructions String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  orderItems          OrderItem[]

  @@index([customerId, status])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int
  price       Float
  farmerId    Int
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([farmerId])
  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  tx_ref    String   @unique
  amount    Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String   @default("SYSTEM")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id          Int       @id @default(autoincrement())
  farmerId    Int
  amount      Float
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  farmer      User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}
